# ── Aurora RDS PostgreSQL ─────────────────────────
# Shared RDS cluster — VPN uses its OWN database (vpn_platform)
# completely isolated from supercard DB
DATABASE_URL=postgresql+asyncpg://vpn_admin:CHANGE_ME@supercard-db.cluster-cfwqw8ksoip5.ap-southeast-1.rds.amazonaws.com:5432/vpn_platform

# ── Security ──────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_64_CHAR_HEX
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── First Admin ───────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME

# ── App ───────────────────────────────────────────
DEBUG=false
SUBSCRIPTION_BASE_URL=http://YOUR_SERVER_IP

# ── Telegram Bot ──────────────────────────────────
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=CHANGE_ME
# Your Telegram user ID (get from @userinfobot)
TELEGRAM_ADMIN_IDS=YOUR_TELEGRAM_ID
